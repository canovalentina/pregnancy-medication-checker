# Exclude large data files
**/synthea/output/
**/*.jar
**/*.json.gz

# Exclude Python virtual environments
**/.venv/
**/__pycache__/
**/*.pyc

# Exclude logs
**/logs/

# Exclude node_modules (will be installed during build)
**/node_modules/

# Exclude build artifacts
**/dist/
**/build/

# Exclude test files
**/tests/

# Exclude documentation
**/*.pdf
**/*.docx

# Exclude other large directories
tmp/
*.lock

