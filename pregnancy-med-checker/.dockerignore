# Documentation (not needed in container)
*.md
!backend/README.md
docs/

# Test files (optional - remove if you want tests in container)
tests/
backend/tests/
*.test.py
*_test.py
test_*.py

# Large data directories (excluded from .gitignore)
# Exclude DrugBank raw data and scripts
**/drugbank_integration/data/DrugBank/
**/drugbank_integration/scripts/
**/drugbank_integration/data/*.xml
**/drugbank_integration/data/*.sdf
**/drugbank_integration/data/*.fasta
**/drugbank_integration/data/drugbank_interactions_summary.csv
**/drugbank_integration/data/drugbank_interactions_sample.csv
# Note: drugbank_interactions.csv is NOT excluded, so it will be included in Docker if present

# Synthea output and large/generated dirs (keep test bundles for startup ingest)
**/synthea/output/
**/synthea/modules/
**/synthea/modules_to_use/
**/synthea/my_modules/
**/synthea/my_edited_modules/
**/synthea/tmp/
# Do NOT exclude **/synthea/test/ - needed for INGEST_DEMO_AT_STARTUP

# JAR and ZIP files
*.jar
*.zip

# Node (if any in backend)
node_modules/
npm-debug.log*

# Local development files
local/
tmp/

# Vercel
.vercel/

# Docker files themselves
Dockerfile*
docker-compose.yml
.dockerignore

# Makefile (not needed in container)
Makefile

